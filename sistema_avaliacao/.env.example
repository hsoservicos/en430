# ─── Configuração do Sistema de Avaliação ──────────────────────────
# Introdução à Enfermagem (EN_430)
#
# Instruções:
# 1. Copie este arquivo: cp .env.example .env
# 2. Preencha as variáveis abaixo se necessário
# ========================================================================

# ─── Secret Key da Aplicação ─────────────────────────────────────────
# Usada para assinar cookies de sessão. Em produção, use uma chave forte.
# Gere uma com: python3 -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=minha_chave_secreta_aqui

# ─── Admin Secret Key ────────────────────────────────────────────────
# Senha para acessar o painel administrativo em /admin
# ADMIN_SECRET=admin_enfermagem_2026

# ─── NOTA SOBRE RECUPERAÇÃO DE ACESSO ───────────────────────────────
# O sistema de recuperação de senha utiliza Nome e Telefone cadastrados
# para verificar a identidade do estudante. Não é necessário configurar
# servidor SMTP ou serviço de email.
