{
    "name": "en430/sistema-avaliacao",
    "description": "Sistema de Avaliação - Introdução à Enfermagem (EN_430)",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-sqlite3": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "files": [
            "config.php",
            "functions.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html reports/"
    }
}
